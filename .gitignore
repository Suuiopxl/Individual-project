# ==================== API keys ====================
.env
API.txt

# ==================== Build artifacts ====================
*.o
*.mod
*.x
*_build/

# ==================== Profiling data ====================
gmon.out
perf.data*

# ==================== Large / binary files ====================
*.log
*.so
*.a
*.dylib

# ==================== OS files ====================
.DS_Store
Thumbs.db

# ==================== Python ====================
__pycache__/
*.pyc
*.pyo

# ==================== App-specific ignores ====================
# Ignore large build dirs inside cloned app sources
apps/*/build/
apps/*/.git/
apps/*/CMakeFiles/
apps/*/CMakeCache.txt
apps/*_gpu/original_backup/

# LAMMPS specific (very large repo)
apps/LAMMPS/doc/
apps/LAMMPS/examples/
apps/LAMMPS/bench/
apps/LAMMPS/potentials/
apps/LAMMPS/tools/
apps/LAMMPS/cmake/
apps/LAMMPS/unittest/

# LAMMPS is too large for GitHub (~1GB), keep local only
apps/LAMMPS/

# miniFE build artifacts
apps/miniFE_build/
# LAMMPS_gpu: keep src/ + cmake/ + bench/in.lj + cuda_manual/, exclude the rest
apps/LAMMPS_gpu/doc/
apps/LAMMPS_gpu/examples/
apps/LAMMPS_gpu/potentials/
apps/LAMMPS_gpu/tools/
apps/LAMMPS_gpu/unittest/
apps/LAMMPS_gpu/lib/
apps/LAMMPS_gpu/python/
apps/LAMMPS_gpu/fortran/
apps/LAMMPS_gpu/third_party/
apps/LAMMPS_gpu/.github/
apps/LAMMPS_gpu/original_backup/
apps/LAMMPS_gpu/bench/*
!apps/LAMMPS_gpu/bench/in.lj
